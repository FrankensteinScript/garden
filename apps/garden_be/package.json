{
    "name": "@garden/garden_be",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "migration:generate": "bash -c 'pnpm dlx typeorm-ts-node-commonjs migration:generate src/infrastructure/database/migrations/$1 -d src/infrastructure/database/data-source.ts -o' --",
        "migration:run": "pnpm dlx typeorm-ts-node-commonjs migration:run -d src/infrastructure/database/data-source.ts",
        "migration:revert": "pnpm dlx typeorm-ts-node-commonjs migration:revert -d src/infrastructure/database/data-source.ts"
    },
    "nx": {
        "targets": {
            "build": {
                "executor": "nx:run-commands",
                "options": {
                    "command": "tsc -p apps/garden_be/tsconfig.app.json"
                },
                "configurations": {
                    "development": {},
                    "production": {}
                }
            },
            "serve": {
                "executor": "@nx/js:node",
                "options": {
                    "buildTarget": "@garden/garden_be:build"
                },
                "configurations": {
                    "development": {
                        "buildTarget": "@garden/garden_be:build:development"
                    },
                    "production": {
                        "buildTarget": "@garden/garden_be:build:production"
                    }
                }
            }
        }
    },
    "dependencies": {
        "@nestjs/config": "^4.0.2",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/swagger": "11.2.4",
        "bcryptjs": "^3.0.3",
        "class-validator": "^0.14.3",
        "nodemailer": "^8.0.4",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "pg": "8.16.3",
        "reflect-metadata": "0.2.2",
        "typeorm": "0.3.28"
    },
    "devDependencies": {
        "@nx/js": "21.3.11",
        "@types/bcryptjs": "^3.0.0",
        "@types/node": "18.16.9",
        "@types/nodemailer": "^7.0.11",
        "@types/passport-jwt": "^4.0.1",
        "ts-node": "10.9.2",
        "typescript": "5.7.3"
    }
}
