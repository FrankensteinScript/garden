{
    "compileOnSave": false,
    "compilerOptions": {
        "target": "ES2020",
        "module": "Node16",
        "lib": ["ES2020"],
        "declaration": false,
        "sourceMap": true,
        "strict": true,
        "noImplicitAny": true,
        "moduleResolution": "node16",
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "allowJs": true,
        "incremental": true
    },
    "exclude": ["node_modules", "dist", "tmp"]
}
